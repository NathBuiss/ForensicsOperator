{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite dev server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "0.0.0.0"],
      "cwd": "frontend",
      "port": 3000
    },
    {
      "name": "API (FastAPI + uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "api",
      "port": 8000
    },
    {
      "name": "Processor (Celery worker)",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "celery_app", "worker", "--loglevel=info", "--concurrency=2"],
      "cwd": "processor",
      "port": null
    },
    {
      "name": "Full stack (docker-compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "cwd": ".",
      "port": 3000
    }
  ]
}
