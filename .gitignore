# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so
.venv/
venv/
ENV/
env/
.env
.env.*
!.env.example

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Kubernetes secrets (never commit real secrets) ───────────────────────────
k8s/secrets/*.yaml
!k8s/secrets/*.example.yaml

# ── Forensics data (never commit evidence files) ─────────────────────────────
*.evtx
*.plaso
*.pf
$MFT
evidence/
cases/
uploads/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
celery*.log
worker*.log

# ── Test / Coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
.hypothesis/

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

# ── Elasticsearch data (local dev volumes) ────────────────────────────────────
elasticsearch/data/

# ── MinIO data (local dev) ───────────────────────────────────────────────────
minio/data/
